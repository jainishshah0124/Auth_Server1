Gateway services :

	sudo nano /etc/systemd/system/mcp-gateway.service
		==> 
			[Unit]
			Description=MCP OAuth Gateway
			After=network.target

			[Service]
			User=ec2-user
			WorkingDirectory=/home/ec2-user/mcp-gateway
			EnvironmentFile=/etc/mcp-gateway/env
			ExecStart=/home/ec2-user/mcp-gateway/.venv/bin/uvicorn main:app --host 127.0.0.1 --port 8080
			Restart=always
			RestartSec=5

			[Install]
			WantedBy=multi-user.target

Start gateway service
	sudo systemctl daemon-reload
	sudo systemctl enable mcp-gateway
	sudo systemctl start mcp-gateway
	sudo systemctl status mcp-gateway

Config nginx reverse proxy

	sudo nano /etc/nginx/conf.d/mcp-gateway.conf
		==>
			server {
			    listen 80;
			    server_name your-domain.com;

			    location / {
			        proxy_pass http://127.0.0.1:8080;

			        proxy_http_version 1.1;
			        proxy_set_header Host $host;
			        proxy_set_header X-Real-IP $remote_addr;
			        proxy_set_header X-Forwarded-Proto $scheme;
			        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;

			        proxy_buffering off;
			        proxy_read_timeout 3600;
			        proxy_send_timeout 3600;
			    }
			}

